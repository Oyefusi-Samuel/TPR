<launch>
  <arg name="use_sim_time" default="false" />
  
  <!-- 1. Robot State Publisher -->
  <node pkg="robot_state_publisher" exec="robot_state_publisher">
    <param name="robot_description" value="$(command 'xacro $(find-pkg-share jackal_ar4_description)/urdf/jackal_ar4.urdf.xacro use_platform_controllers:=false')" />
    <param name="use_sim_time" value="$(var use_sim_time)" />
  </node>
  
  <!-- 2. Controller Manager -->
  <node pkg="controller_manager" exec="ros2_control_node" name="controller_manager">
    <param from="$(find-pkg-share jackal_ar4_moveit_config)/config/ros2_controllers.yaml" />
    <param name="use_sim_time" value="$(var use_sim_time)" />
  </node>

  <!-- 3. Spawners for Controllers -->
  <node pkg="controller_manager" exec="spawner" args="joint_state_broadcaster" />
  <node pkg="controller_manager" exec="spawner" args="arm_controller" />
  <node pkg="controller_manager" exec="spawner" args="ar_gripper_controller" />
  
  <!-- 4. Ground Truth Odometry -->
  <node pkg="jackal_ar4_navigation" exec="ground_truth_odom.py" name="ground_truth_odom">
    <param name="use_sim_time" value="$(var use_sim_time)" />
  </node>

  <!-- 5. Static Transform -->
  <node pkg="tf2_ros" exec="static_transform_publisher" name="map_to_odom" args="--x 0 --y 0 --z 0 --yaw 0 --pitch 0 --roll 0 --frame-id map --child-frame-id odom" />

  <!-- 6. Navigation (Nav2) -->
  <include file="$(find-pkg-share jackal_ar4_navigation)/launch/navigation.launch.py">
    <arg name="use_sim_time" value="$(var use_sim_time)" />
  </include>

  <!-- 7. MoveIt2 Move Group -->
  <include file="$(find-pkg-share jackal_ar4_moveit_config)/launch/move_group.launch.py" />

  <!-- 8. RViz2 (MoveIt Aware) -->
  <include file="$(find-pkg-share jackal_ar4_moveit_config)/launch/rviz.launch.py" />
</launch>
